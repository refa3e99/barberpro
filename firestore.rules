rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      // For this app we might rely on google auth which auto-verifies, but enforcing it is secure.
      // return request.auth.token.email_verified == true;
      // Note: Google sign-in guarantees email_verified is true for legitimate google emails.
      return request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'email', 'name', 'role', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 200
        && data.role in ['customer', 'admin']
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();

      allow create: if isSignedIn() && isVerifiedEmail() && request.auth.uid == userId && isValidId(userId)
                    && isValidUserProfile(incoming())
                    && incoming().keys().size() == 5
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time
                    && incoming().email == request.auth.token.email
                    && (incoming().role == 'customer' || (incoming().role == 'admin' && request.auth.token.email == 'refa3e7899@gmail.com'));

      allow update: if isSignedIn() && isVerifiedEmail() && isValidId(userId) && isValidUserProfile(incoming())
                    && incoming().userId == existing().userId
                    && incoming().email == existing().email
                    && incoming().createdAt == existing().createdAt
                    && (
                      isAdmin() ||
                      (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name']))
                    );
    }

    // --- Services ---
    function isValidService(data) {
      return data.keys().hasAll(['name', 'duration', 'price', 'isActive', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.duration is number
        && data.price is number
        && data.isActive is bool
        && data.createdAt is timestamp;
    }

    match /services/{serviceId} {
      allow get: if isSignedIn() && isValidId(serviceId);
      allow list: if isSignedIn() && resource.data.isActive == true;
      allow list: if isAdmin();

      allow create: if isAdmin() && isValidId(serviceId)
                    && isValidService(incoming())
                    && incoming().keys().size() == 5
                    && incoming().createdAt == request.time;

      allow update: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      
      allow delete: if isAdmin() && isValidId(serviceId);
    }

    // --- Barber Availability ---
    function isValidAvailability(data) {
      return data.keys().hasAll(['startTime', 'endTime', 'type'])
        && data.startTime is timestamp
        && data.endTime is timestamp
        && data.type in ['working', 'blocked'];
    }

    match /users/{userId}/availability/{slotId} {
      allow get, list: if isSignedIn() && isValidId(userId);

      allow create, update, delete: if isAdmin() && request.auth.uid == userId
                    && isValidId(slotId)
                    && (request.method != 'DELETE' ? isValidAvailability(incoming()) : true);
    }

    // --- Appointments ---
    function isValidAppointment(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'customerPhone', 'barberId', 'serviceId', 'startTime', 'endTime', 'status', 'createdAt', 'updatedAt'])
        && data.customerId is string && data.customerId.size() <= 128
        && data.customerName is string && data.customerName.size() >= 2 && data.customerName.size() <= 100
        && data.customerPhone is string && data.customerPhone.matches('^(00962|\\+962|0)7[789]\\d{7}$')
        && data.barberId is string && data.barberId.size() <= 128
        && data.serviceId is string && data.serviceId.size() <= 128
        && data.startTime is timestamp
        && data.endTime is timestamp
        && data.status in ['pending', 'confirmed', 'completed', 'canceled']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && isValidId(appointmentId) && (
        resource.data.customerId == request.auth.uid ||
        isAdmin()
      );

      allow list: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isSignedIn() && isVerifiedEmail() && isValidId(appointmentId)
                    && isValidAppointment(incoming())
                    && incoming().keys().size() == 10
                    && (incoming().customerId == request.auth.uid || isAdmin())
                    && incoming().startTime > request.time
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time
                    && (isAdmin() || incoming().status == 'pending')
                    && (isAdmin() || (exists(/databases/$(database)/documents/users/$(incoming().customerId)) && incoming().customerId == request.auth.uid))
                    && exists(/databases/$(database)/documents/services/$(incoming().serviceId));

      allow update: if isSignedIn() && isVerifiedEmail() && isValidId(appointmentId) && isValidAppointment(incoming())
                    && incoming().updatedAt == request.time
                    && incoming().customerId == existing().customerId
                    && incoming().serviceId == existing().serviceId
                    && incoming().createdAt == existing().createdAt
                    && (
                      isAdmin() ||
                      (request.auth.uid == existing().customerId && incoming().diff(existing()).affectedKeys().hasOnly(['startTime', 'endTime', 'status', 'updatedAt']) && (incoming().status == 'canceled' || incoming().status == 'pending'))
                    );
    }
  }
}
